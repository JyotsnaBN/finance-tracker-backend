# Finance Tracker — local development environment variables
# Copy this file to backend/.env and fill in your dev values.
# Never commit the real .env file (it is already in .gitignore).

ENCRYPTION_SECRET_KEY=  # Exactly 32 chars (AES-256-GCM key)

GOOGLE_CLIENT_ID=       # Google Cloud Console OAuth2 client ID
GOOGLE_CLIENT_SECRET=   # Google Cloud Console OAuth2 client secret
GOOGLE_REDIRECT_URI=    # http://localhost:8080/api/email/oauth/callback

EMAIL_SYNC_FREQUENCY_MS=    # Polling interval in ms, e.g. 3600000 (1 h)
EMAIL_SYNC_MAX_RESULTS=     # Max emails to fetch per sync, e.g. 100
EMAIL_SYNC_LOOKBACK_DAYS=   # How far back to scan on first sync, e.g. 30

DATABASE_URL=           # JDBC URL: jdbc:postgresql://db.<ref>.supabase.co:5432/postgres
DATABASE_USERNAME=      # DB user (usually 'postgres')
DATABASE_PASSWORD=      # DB password

JWT_SECRET=             # Min 32 chars, random string

BACKEND_BASE_URL=       # e.g. http://localhost:8080 (used by GitHub Actions cron)
INTERNAL_API_KEY=       # Random string for X-API-KEY header (email processing endpoint)

PORT=                   # Server port, defaults to 8080 if unset

# Set to true ONCE to encrypt any plain-text account numbers already in the DB.
# Remove or set to false after the app has started successfully with it enabled.
MIGRATION_ACCOUNT_NUMBER_ENABLED=  # true | false (default: false)
